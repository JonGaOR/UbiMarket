    </div>

    <nav class="menu-pags">
      <ul class="nav-pags">
        <a href="#">
          <li class="pag destacado">Inicio</li>
        </a>
        <a href="#">
          <li class="pag">Descarga</li>
        </a>
        <a href="#">
          <li class="pag">Nosotros</li>
        </a>
        <a href="#">
          <li class="pag">Equipo</li>
        </a>
        <a href="#">
          <li class="pag">Soporte</li>
        </a>
      </ul>
    </nav>

    <div class="cont-menu-amburguesa" id="menu-amburguesa">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="#ffffff"><path d="M120-240v-80h720v80H120Zm0-200v-80h720v80H120Zm0-200v-80h720v80H120Z"/></svg>
    </div>

    <div class="cont-menu-movil" id="menu-movil">
