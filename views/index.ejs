    <section class="descargar">
      <div class="cont-descargar">
        <h1 class="tlt-descargar">¿Listo para empezar?</h1>
        <p class="txt-descargar">Descarga ahora y descubre todo lo que nuestra app puede hacer por ti</p>

        <div class="cont-btn-descargar">
          <div class="cont-svg-descargar">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="#000000"><path d="M480-320 280-520l56-58 104 104v-326h80v326l104-104 56 58-200 200ZM240-160q-33 0-56.5-23.5T160-240v-120h80v120h480v-120h80v120q0 33-23.5 56.5T720-160H240Z"/></svg>
          </div>
          <p class="txt-btn-descargar">Descargar</p>
        </div>
      </div>
      <hr color="#C29947" width="100%">
    </section>

    <section class="enlaces">
      <div class="cont-enlaces">
        <article class="eslogan-enlaces">
          <div class="cont-eslogan-enlaces">
            <div class="cont-img-eslogan-enlaces">
              <img src="img/UbiMarketIcono.png" alt="" class="img-eslogan-enlaces">
            </div>
            <h1 class="nombre-eslogan-enlaces">UbiMarket</h1>
          </div>
          <p class="txt-eslogan-enlaces">La aplicación que revoluciona tu forma de emprender</p>
        </article>

        <div class="cont-enlaces-rapidos">
          <p class="tlt-enlaces-rapidos destacado">Enlaces rápidos</p>
          <nav class="enlaces-rapidos">
            <ul class="lista-enlaces-rapidos">
